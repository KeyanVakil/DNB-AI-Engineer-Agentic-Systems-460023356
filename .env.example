# FinSight Agents — local development defaults
# Copy to .env and adjust as needed.

FINSIGHT_ENV=development
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgresql+asyncpg://finsight:finsight@localhost:5432/finsight

# --- LLM provider (default: Ollama, zero API key) ---
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://ollama:11434
EMBED_MODEL=nomic-embed-text

# Switch to OpenAI:  LLM_PROVIDER=openai  LLM_MODEL=gpt-4o-mini  OPENAI_API_KEY=sk-...
# Switch to Anthropic: LLM_PROVIDER=anthropic  LLM_MODEL=claude-haiku-20240307  ANTHROPIC_API_KEY=...
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- MCP server URLs ---
CUSTOMER_MCP_URL=http://customer-mcp:7001
MARKET_MCP_URL=http://market-mcp:7002
COMPLIANCE_MCP_URL=http://compliance-mcp:7003

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- OpenTelemetry ---
OTEL_SDK_DISABLED=false
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=finsight-agents

# --- Prompt versions ---
DEFAULT_PROMPT_VERSION=v1
